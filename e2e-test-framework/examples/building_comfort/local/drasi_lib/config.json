{
  "data_store": {
    "data_store_path": "./test_data_cache",
    "delete_on_start": true,
    "delete_on_stop": true,
    "test_repos": [
      {
        "id": "drasi_lib_dev_repo",
        "kind": "LocalStorage",
        "source_path": "./dev_repo",
        "local_tests": [
          {
            "test_id": "building_comfort",
            "version": 1,
            "description": "Building comfort monitoring test with drasi-lib instance",
            "test_folder": "building_comfort",
            "queries": [],
            "sources": [
              {
                "test_source_id": "facilities-db",
                "kind": "Model",
                "source_change_dispatchers": [
                  {
                    "kind": "DrasiLibInstanceChannel",
                    "source_id": "facilities-db",
                    "buffer_size": 2048,
                    "drasi_lib_instance_id": "internal-drasi-lib"
                  }
                ],
                "model_data_generator": {
                  "kind": "BuildingHierarchy",
                  "change_interval": [
                    5000000000,
                    1000000000,
                    1000000000,
                    5000000000
                  ],
                  "change_count": 100000,
                  "send_initial_inserts": true,
                  "seed": 123456789,
                  "spacing_mode": "none",
                  "time_mode": "2025-01-03T10:03:15.4Z",
                  "building_count": [
                    1,
                    0
                  ],
                  "floor_count": [
                    1,
                    0
                  ],
                  "room_count": [
                    1,
                    0
                  ],
                  "room_sensors": [
                    {
                      "kind": "NormalFloat",
                      "id": "temperature",
                      "momentum_init": [
                        5,
                        1,
                        0.5
                      ],
                      "value_change": [
                        1,
                        0
                      ],
                      "value_init": [
                        5000,
                        0
                      ],
                      "value_range": [
                        0,
                        10000
                      ]
                    },
                    {
                      "kind": "NormalFloat",
                      "id": "co2",
                      "momentum_init": [
                        10,
                        1,
                        0.5
                      ],
                      "value_change": [
                        1,
                        0
                      ],
                      "value_init": [
                        5000,
                        0
                      ],
                      "value_range": [
                        0,
                        10000
                      ]
                    },
                    {
                      "kind": "NormalFloat",
                      "id": "humidity",
                      "momentum_init": [
                        5,
                        1,
                        0.5
                      ],
                      "value_change": [
                        1,
                        0
                      ],
                      "value_init": [
                        5000,
                        0
                      ],
                      "value_range": [
                        0,
                        10000
                      ]
                    }
                  ]
                },
                "subscribers": []
              }
            ],
            "reactions": [
              {
                "test_reaction_id": "building-comfort",
                "output_handler": {
                  "kind": "DrasiLibInstanceChannel",
                  "reaction_id": "building-comfort-alerts",
                  "buffer_size": 1024,
                  "drasi_lib_instance_id": "internal-drasi-lib"
                },
                "stop_triggers": [
                  {
                    "kind": "RecordCount",
                    "record_count": 99000
                  }
                ]
              }
            ],
            "drasi_lib_instances": [
              {
                "test_drasi_lib_instance_id": "internal-drasi-lib",
                "name": "Internal drasi-lib instance for Building Comfort",
                "description": "Embedded drasi-lib instance for testing",
                "config": {
                  "log_level": "info",
                  "sources": [
                    {
                      "id": "facilities-db",
                      "kind": "application",
                      "auto_start": true,
                      "config": {}
                    }
                  ],
                  "queries": [
                    {
                      "id": "all-rooms",
                      "query": "MATCH (r:Room) RETURN elementId(r) AS RoomId, r.temperature, r.humidity, r.co2",
                      "sources": [
                        "facilities-db"
                      ],
                      "auto_start": true,
                      "config": {}
                    }
                  ],
                  "reactions": [
                    {
                      "id": "building-comfort-alerts",
                      "kind": "application",
                      "queries": [
                        "all-rooms"
                      ],
                      "auto_start": true,
                      "config": {}
                    }
                  ]
                }
              }
            ]
          }
        ]
      }
    ]
  },
  "test_run_host": {
    "test_runs": [
      {
        "test_id": "building_comfort",
        "test_repo_id": "drasi_lib_dev_repo",
        "test_run_id": "test_run_001",
        "queries": [],
        "reactions": [
          {
            "test_reaction_id": "building-comfort",
            "start_immediately": true,
            "output_loggers": [
              {
                "kind": "JsonlFile",
                "max_lines_per_file": 15000
              },
              {
                "kind": "PerformanceMetrics"
              }
            ]
          }
        ],
        "sources": [
          {
            "test_source_id": "facilities-db",
            "start_mode": "auto",
            "test_run_overrides": {
              "model_data_generator": {}
            }
          }
        ],
        "drasi_lib_instances": [
          {
            "test_drasi_lib_instance_id": "internal-drasi-lib",
            "start_immediately": true
          }
        ]
      }
    ]
  }
}
