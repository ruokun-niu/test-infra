# This file is for use with the REST Client extension for Visual Studio Code to make it easy to manually 
# test the Test Service Web API.
# https://marketplace.visualstudio.com/items?itemName=humao.rest-client

@hostname = localhost
@port = 63123
@repo_id = github_dev_repo
@test_id = building_comfort
@test_run_id = test_run_001
@query_id = room-comfort-level

@fq_test_run_id = {{repo_id}}.{{test_id}}.{{test_run_id}}

### GET LIST of Test Run Queries
GET http://{{hostname}}:{{port}}/api/test_runs/{{fq_test_run_id}}/queries

### GET STATE of Test Run Query
GET http://{{hostname}}:{{port}}/api/test_runs/{{fq_test_run_id}}/queries/{{query_id}}

### START Test Run Query
POST http://{{hostname}}:{{port}}/api/test_runs/{{fq_test_run_id}}/queries/{{query_id}}/start
Content-Type: application/json

### PAUSE Test Run Query
POST http://{{hostname}}:{{port}}/api/test_runs/{{fq_test_run_id}}/queries/{{query_id}}/pause
Content-Type: application/json

### STOP Test Run Query
POST http://{{hostname}}:{{port}}/api/test_runs/{{fq_test_run_id}}/queries/{{query_id}}/stop
Content-Type: application/json

### RESET Test Run Query
POST http://{{hostname}}:{{port}}/api/test_runs/{{fq_test_run_id}}/queries/{{query_id}}/reset
Content-Type: application/json