{
  "data_store": {
      "data_store_path": "./test_data_cache",
      "delete_on_start": true,
      "delete_on_stop": true,
      "test_repos": [
          {
              "id": "drasi_server_dev_repo",
              "kind": "LocalStorage",
              "source_path": "./dev_repo",
              "local_tests": [
                  {
                      "test_id": "stock_market",
                      "version": 1,
                      "description": "Stocks (Model/HTTP) joined with a slow-changing watchlist (Script/gRPC). Cypher query MATCH (s:Stock),(w:WatchlistItem) WHERE s.symbol = w.symbol returns only watchlisted stock prices.",
                      "test_folder": "stock_market",
                      "queries": [],
                      "sources": [
                          {
                              "test_source_id": "stock-trades-db",
                              "kind": "Model",
                              "source_change_dispatchers": [
                                  {
                                      "kind": "Http",
                                      "url": "http://localhost",
                                      "port": 9000,
                                      "timeout_seconds": 60,
                                      "batch_events": false
                                  },
                                  {
                                      "kind": "JsonlFile",
                                      "max_lines_per_file": 15000
                                  }
                              ],
                              "model_data_generator": {
                                  "kind": "StockTrade",
                                  "stock_definitions": [
                                      { "symbol": "MSFT",  "name": "Microsoft Corporation" },
                                      { "symbol": "AAPL",  "name": "Apple Inc." },
                                      { "symbol": "GOOGL", "name": "Alphabet Inc." },
                                      { "symbol": "AMZN",  "name": "Amazon.com Inc." },
                                      { "symbol": "NVDA",  "name": "NVIDIA Corporation" },
                                      { "symbol": "TSLA",  "name": "Tesla Inc." },
                                      { "symbol": "META",  "name": "Meta Platforms Inc." },
                                      { "symbol": "BRK.B", "name": "Berkshire Hathaway Inc." },
                                      { "symbol": "V",     "name": "Visa Inc." },
                                      { "symbol": "JPM",   "name": "JPMorgan Chase & Co." }
                                  ],
                                  "price_init": [150.0, 50.0],
                                  "price_change": [0.5, 2.0],
                                  "price_momentum": [5, 2.0, 0.3],
                                  "price_range": [10.0, 5000.0],
                                  "volume_init": [10000000, 5000000.0],
                                  "volume_change": [100000, 50000.0],
                                  "volume_momentum": [3, 1.5, 0.4],
                                  "volume_range": [1000, 100000000],
                                  "change_count": 2000,
                                  "change_interval": [15000000, 3000000, 5000000, 30000000],
                                  "spacing_mode": "recorded",
                                  "time_mode": "live",
                                  "seed": 123456789,
                                  "send_initial_inserts": true
                              },
                              "subscribers": [
                                  { "node_id": "default", "query_id": "watchlist-prices" }
                              ]
                          },
                          {
                              "test_source_id": "watchlist-db",
                              "kind": "Script",
                              "source_change_generator": {
                                  "kind": "Script",
                                  "script_file_folder": "source_change_scripts",
                                  "spacing_mode": "recorded",
                                  "time_mode": "live",
                                  "ignore_scripted_pause_commands": false
                              },
                              "source_change_dispatchers": [
                                  {
                                      "kind": "Grpc",
                                      "host": "localhost",
                                      "port": 50051,
                                      "timeout_seconds": 60,
                                      "batch_events": false,
                                      "tls": false,
                                      "source_id": "watchlist-db"
                                  },
                                  {
                                      "kind": "JsonlFile",
                                      "max_lines_per_file": 15000
                                  }
                              ],
                              "subscribers": [
                                  { "node_id": "default", "query_id": "watchlist-prices" }
                              ]
                          }
                      ],
                      "reactions": [
                          {
                              "test_reaction_id": "watchlist-prices",
                              "output_handler": {
                                  "kind": "Http",
                                  "port": 9002,
                                  "path": "/reaction",
                                  "correlation_header": "X-Query-Sequence"
                              },
                              "stop_triggers": [
                                  {
                                      "kind": "RecordCount",
                                      "record_count": 100
                                  }
                              ]
                          }
                      ]
                  }
              ]
          }
      ]
  },
  "test_run_host": {
      "test_runs": [
          {
              "test_id": "stock_market",
              "test_repo_id": "drasi_server_dev_repo",
              "test_run_id": "test_run_001",
              "queries": [],
              "reactions": [
                  {
                      "test_reaction_id": "watchlist-prices",
                      "start_immediately": true,
                      "output_loggers": [
                          {
                              "kind": "JsonlFile",
                              "max_lines_per_file": 15000
                          },
                          {
                              "kind": "PerformanceMetrics"
                          }
                      ]
                  }
              ],
              "sources": [
                  {
                      "test_source_id": "stock-trades-db",
                      "start_mode": "auto",
                      "test_run_overrides": {
                          "model_data_generator": {}
                      }
                  },
                  {
                      "test_source_id": "watchlist-db",
                      "start_mode": "auto",
                      "test_run_overrides": {}
                  }
              ]
          }
      ]
  }
}
